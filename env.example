# Optionnel : pour connecter la bibliothèque Spotify (titres + pochettes)
# Créez une app sur https://developer.spotify.com/dashboard
# Ajoutez http://localhost:3000/api/spotify/callback dans "Redirect URIs"
# Renommez ce fichier en .env et remplissez les valeurs.

SPOTIFY_CLIENT_ID=votre_client_id
SPOTIFY_CLIENT_SECRET=votre_client_secret
