rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utilisateurs : pour les écoutants, seuls pseudo, date (createdAt) et badges sont stockés.
    // Les données confidentielles (email, tél, carte d'identité, diplôme) sont envoyées par mail uniquement.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        (request.auth.uid == userId || request.auth.uid == 'FWrrl4ZGDhRLEjYkIw1H3AFIgtf2');

      match /badge/{badgeId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Règles pour les sessions (réservations)
    match /sessions/{sessionId} {
      // Lecture : tout utilisateur connecté (pour afficher les créneaux déjà pris)
      allow read: if request.auth != null;
      // Les utilisateurs peuvent créer des sessions où ils sont impliqués
      allow create: if request.auth != null && 
        (request.resource.data.appelantId == request.auth.uid || 
         request.resource.data.ecoutantId == request.auth.uid);
      // Les utilisateurs peuvent mettre à jour leurs propres sessions
      allow update: if request.auth != null && 
        (resource.data.appelantId == request.auth.uid || 
         resource.data.ecoutantId == request.auth.uid);
    }
  }
}
